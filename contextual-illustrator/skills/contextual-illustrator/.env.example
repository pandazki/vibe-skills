# Configure at least one backend. If both are present, fal.ai is preferred.

# fal.ai (recommended; required for the default gpt-image-2 model)
# Get your key: https://fal.ai/dashboard/keys
FAL_KEY=

# OpenRouter (fallback, Gemini 3 Pro only, no extra Python deps)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
